<script>
(function(){
"use strict";

/* ============ ICONS ============ */
const ICONS = {
  dashboard:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1.5"></rect><rect x="14" y="3" width="7" height="5" rx="1.5"></rect><rect x="14" y="12" width="7" height="9" rx="1.5"></rect><rect x="3" y="16" width="7" height="5" rx="1.5"></rect></svg>',
  tasks:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="17" rx="2"></rect><path d="m8 12 2.5 2.5L16 9"></path></svg>',
  calendar:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="16" rx="2"></rect><path d="M8 3v4M16 3v4M3 10h18"></path></svg>',
  users:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.2"></circle><path d="M2.5 20c1-3.6 3.6-5.5 6.5-5.5s5.5 1.9 6.5 5.5"></path><circle cx="17.5" cy="7.5" r="2.4"></circle><path d="M15.8 14.7c2.5.4 4.3 2.1 5.1 5.3"></path></svg>',
  analytics:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 20V10M12 20V4M20 20v-7"></path></svg>',
  edit:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"></path></svg>',
  trash:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2m3 0-.9 14a2 2 0 0 1-2 1.9H7.9a2 2 0 0 1-2-1.9L5 6"></path></svg>',
  clock:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 3"></path></svg>',
  check:'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>'
};

/* ============ STATE ============ */
const AVATAR_COLORS = ['#5B5FEF','#0F9D77','#C7830B','#D6393E','#2563EB','#9333EA','#0891B2'];
function initials(name){ return name.split(' ').map(p=>p[0]).slice(0,2).join('').toUpperCase(); }
function colorFor(id){ let h=0; for(const c of id) h=(h*31+c.charCodeAt(0))>>>0; return AVATAR_COLORS[h%AVATAR_COLORS.length]; }

let uidN = 1000;
function uid(prefix){ return prefix+'-'+(++uidN); }

function isoDate(d){ return d.toISOString().slice(0,10); }
function addDays(base,n){ const d=new Date(base); d.setDate(d.getDate()+n); return d; }

const TODAY = new Date('2026-07-02T00:00:00');

const state = {
  currentView:'dashboard',
  theme:'light',
  users: [
    {id:'u1', name:'Jordan Miles', email:'jordan.miles@orbit.io', role:'Project Manager'},
    {id:'u2', name:'Priya Sharma', email:'priya.sharma@orbit.io', role:'Developer'},
    {id:'u3', name:'Marcus Lee', email:'marcus.lee@orbit.io', role:'Designer'},
    {id:'u4', name:'Elena Vasquez', email:'elena.vasquez@orbit.io', role:'QA Engineer'},
    {id:'u5', name:'Sam Okafor', email:'sam.okafor@orbit.io', role:'Marketing'}
  ],
  projects: [
    {id:'p1', name:'Aurora Redesign', color:'#5B5FEF'},
    {id:'p2', name:'Mobile App v2', color:'#0F9D77'},
    {id:'p3', name:'Q3 Campaign', color:'#C7830B'}
  ],
  tasks: [],
  filters:{project:'',assignee:'',priority:''}
};

function seedTasks(){
  const titles = [
    ['Audit current design system','p1','u3','high'],
    ['Wireframe new dashboard layout','p1','u3','medium'],
    ['Set up component library in Figma','p1','u3','low'],
    ['Migrate auth service to OAuth2','p2','u2','high'],
    ['Build offline sync module','p2','u2','high'],
    ['Fix crash on Android 14 devices','p2','u4','high'],
    ['Write regression test suite','p2','u4','medium'],
    ['Draft Q3 social calendar','p3','u5','medium'],
    ['Finalize campaign budget','p3','u1','low'],
    ['Coordinate influencer outreach','p3','u5','medium'],
    ['Review onboarding copy','p1','u1','low'],
    ['User interview synthesis','p1','u3','medium'],
    ['Set up CI/CD pipeline','p2','u2','medium'],
    ['Prepare investor update deck','p3','u1','high'],
    ['Accessibility audit for checkout','p1','u4','medium'],
    ['Launch landing page A/B test','p3','u5','low']
  ];
  const statuses = ['todo','inprogress','review','done'];
  const dueOffsets = [-3,-1,0,1,2,3,4,5,6,7,9,10,-2,3,5,1];
  titles.forEach((t,i)=>{
    state.tasks.push({
      id: uid('t'),
      title:t[0],
      description:'',
      projectId:t[1],
      assigneeId:t[2],
      priority:t[3],
      status: i%7===0 ? 'done' : statuses[i%4],
      due: isoDate(addDays(TODAY,dueOffsets[i]))
    });
  });
  // force a good spread of done tasks for momentum ring
  state.tasks[0].status='done'; state.tasks[3].status='done'; state.tasks[8].status='done';
  state.tasks[10].status='done'; state.tasks[13].status='inprogress';
}
seedTasks();

const STATUS_META = {
  todo:{label:'To Do', color:'#68708A'},
  inprogress:{label:'In Progress', color:'#2563EB'},
  review:{label:'In Review', color:'#C7830B'},
  done:{label:'Done', color:'#0F9D77'}
};
const PRIORITY_META = {
  high:{label:'High', varName:'--danger', tint:'--danger-tint'},
  medium:{label:'Medium', varName:'--warning', tint:'--warning-tint'},
  low:{label:'Low', varName:'--accent', tint:'--accent-tint'}
};

function css(varName){ return getComputedStyle(document.body).getPropertyValue(varName).trim(); }
function userById(id){ return state.users.find(u=>u.id===id); }
function projectById(id){ return state.projects.find(p=>p.id===id); }
function fmtDate(iso){ const d=new Date(iso+'T00:00:00'); return d.toLocaleDateString('en-US',{month:'short',day:'numeric'}); }

function toast(msg, iconKey){
  const c = document.getElementById('toastContainer');
  const el = document.createElement('div');
  el.className='toast';
  el.innerHTML = (iconKey?ICONS[iconKey]:'')+`<span>${msg}</span>`;
  c.appendChild(el);
  setTimeout(()=>{ el.style.transition='opacity .3s'; el.style.opacity='0'; setTimeout(()=>el.remove(),300); }, 2400);
}

/* ============ NAV / SIDEBAR ============ */
const NAV_ITEMS = [
  {id:'dashboard', label:'Dashboard', icon:'dashboard'},
  {id:'tasks', label:'Tasks', icon:'tasks'},
  {id:'calendar', label:'Calendar', icon:'calendar'},
  {id:'users', label:'Team', icon:'users'},
  {id:'analytics', label:'Analytics', icon:'analytics'}
];
function renderNav(){
  const nav = document.getElementById('navList');
  nav.innerHTML = NAV_ITEMS.map(item=>{
    let count = '';
    if(item.id==='tasks') count = state.tasks.length;
    if(item.id==='users') count = state.users.length;
    return `<button class="nav-item ${state.currentView===item.id?'active':''}" data-view="${item.id}">
      ${ICONS[item.icon]}<span>${item.label}</span>${count!==''?`<span class="nav-count">${count}</span>`:''}
    </button>`;
  }).join('');
  nav.querySelectorAll('.nav-item').forEach(btn=>{
    btn.addEventListener('click', ()=>switchView(btn.dataset.view));
  });
}

const VIEW_TITLES = {dashboard:'Dashboard', tasks:'Tasks', calendar:'Calendar', users:'Team', analytics:'Analytics'};
function switchView(view){
  state.currentView = view;
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.getElementById('view-'+view).classList.add('active');
  document.getElementById('topbarTitle').textContent = VIEW_TITLES[view];
  document.getElementById('topAddBtn').style.display = (view==='users') ? 'none' : 'inline-flex';
  renderNav();
  closeSidebarMobile();
  if(view==='analytics') renderAnalytics();
  if(view==='calendar') renderCalendar();
}

function closeSidebarMobile(){
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('active');
}
document.getElementById('hamburgerBtn').addEventListener('click', ()=>{
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebarOverlay').classList.toggle('active');
});
document.getElementById('sidebarOverlay').addEventListener('click', closeSidebarMobile);

/* ============ THEME ============ */
function applyTheme(){
  document.body.setAttribute('data-theme', state.theme);
  const label = document.getElementById('themeLabel');
  label.innerHTML = (state.theme==='dark'
    ? '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path></svg>Dark mode'
    : '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path></svg>Light mode');
  if(state.currentView==='analytics') renderAnalytics();
  renderDashboard(); // refresh ring color
}
document.getElementById('themeSwitch').addEventListener('click', ()=>{
  state.theme = state.theme==='dark' ? 'light' : 'dark';
  applyTheme();
});

/* ============ SELECT OPTIONS SYNC ============ */
function fillSelectOptions(){
  const projSel = document.getElementById('taskProject');
  projSel.innerHTML = state.projects.map(p=>`<option value="${p.id}">${p.name}</option>`).join('');
  const asgSel = document.getElementById('taskAssignee');
  asgSel.innerHTML = state.users.map(u=>`<option value="${u.id}">${u.name}</option>`).join('');

  const filterProj = document.getElementById('filterProject');
  filterProj.innerHTML = '<option value="">All Projects</option>' + state.projects.map(p=>`<option value="${p.id}">${p.name}</option>`).join('');
  const filterAsg = document.getElementById('filterAssignee');
  filterAsg.innerHTML = '<option value="">All Assignees</option>' + state.users.map(u=>`<option value="${u.id}">${u.name}</option>`).join('');
}

/* ============ DASHBOARD ============ */
function renderDashboard(){
  const total = state.tasks.length;
  const done = state.tasks.filter(t=>t.status==='done').length;
  const inprogress = state.tasks.filter(t=>t.status==='inprogress').length;
  const overdue = state.tasks.filter(t=>t.status!=='done' && t.due < isoDate(TODAY)).length;
  const pct = total? Math.round(done/total*100) : 0;

  const stats = [
    {label:'Total Tasks', value:total, color:'--primary'},
    {label:'Completed', value:done, color:'--accent'},
    {label:'In Progress', value:inprogress, color:'--info'},
    {label:'Overdue', value:overdue, color:'--danger'}
  ];
  document.getElementById('statGrid').innerHTML = stats.map(s=>`
    <div class="stat-card">
      <span class="stat-label">${s.label}</span>
      <span class="stat-value">${s.value}</span>
      <div class="stat-bar-track"><div class="stat-bar-fill" style="width:${total?Math.round(s.value/total*100):0}%;background:var(${s.color})"></div></div>
    </div>`).join('');

  // momentum ring
  const r = 70, c = 2*Math.PI*r;
  const circle = document.getElementById('momentumCircle');
  circle.style.strokeDasharray = c;
  circle.style.strokeDashoffset = c - (pct/100)*c;
  document.getElementById('momentumPct').textContent = pct+'%';

  const breakdown = ['todo','inprogress','review','done'].map(s=>{
    const n = state.tasks.filter(t=>t.status===s).length;
    return `<div class="sb-row"><span class="sb-dot" style="background:${STATUS_META[s].color}"></span><span class="sb-name">${STATUS_META[s].label}</span><span class="sb-val">${n}</span></div>`;
  }).join('');
  document.getElementById('statusBreakdown').innerHTML = breakdown;

  // deadlines
  const upcoming = state.tasks.filter(t=>t.status!=='done').slice().sort((a,b)=>a.due<b.due?-1:1).slice(0,6);
  document.getElementById('deadlineList').innerHTML = upcoming.map(t=>{
    const d = new Date(t.due+'T00:00:00');
    const isOverdue = t.due < isoDate(TODAY);
    return `<li class="deadline-item ${isOverdue?'overdue':''}">
      <div class="deadline-date"><b>${d.getDate()}</b><span>${d.toLocaleDateString('en-US',{month:'short'})}</span></div>
      <div class="deadline-info">
        <div class="deadline-title">${t.title}</div>
        <div class="deadline-meta">${projectById(t.projectId)?.name||''} · ${userById(t.assigneeId)?.name.split(' ')[0]||''}</div>
      </div>
    </li>`;
  }).join('') || '<li class="deadline-meta">Nothing upcoming — nice and clear.</li>';

  // recent tasks
  const recent = state.tasks.slice(-6).reverse();
  document.getElementById('recentTasks').innerHTML = recent.map(t=>`
    <div class="mini-task">
      <div class="mini-task-prio" style="background:var(${PRIORITY_META[t.priority].varName})"></div>
      <div class="mini-task-body">
        <div class="mini-task-title">${t.title}</div>
        <div class="mini-task-meta">${projectById(t.projectId)?.name||''} · Due ${fmtDate(t.due)}</div>
      </div>
      <span class="pill" style="background:${STATUS_META[t.status].color}22;color:${STATUS_META[t.status].color}">${STATUS_META[t.status].label}</span>
    </div>`).join('');
}

/* ============ TASKS / KANBAN ============ */
let draggedTaskId = null;

function filteredTasks(){
  return state.tasks.filter(t=>
    (!state.filters.project || t.projectId===state.filters.project) &&
    (!state.filters.assignee || t.assigneeId===state.filters.assignee) &&
    (!state.filters.priority || t.priority===state.filters.priority)
  );
}

function taskCardHTML(t){
  const isOverdue = t.status!=='done' && t.due < isoDate(TODAY);
  const u = userById(t.assigneeId);
  return `<div class="task-card prio-${t.priority}" draggable="true" data-id="${t.id}">
    <div class="task-card-top">
      <span class="task-project">${projectById(t.projectId)?.name||''}</span>
      <div class="avatar sm" style="background:${colorFor(t.assigneeId)}">${u?initials(u.name):''}</div>
    </div>
    <div class="task-title">${t.title}</div>
    <div class="task-card-bottom">
      <span class="task-due ${isOverdue?'overdue':''}">${ICONS.clock}${fmtDate(t.due)}</span>
      <span class="pill" style="background:var(${PRIORITY_META[t.priority].tint});color:var(${PRIORITY_META[t.priority].varName})">${PRIORITY_META[t.priority].label}</span>
    </div>
  </div>`;
}

function renderBoard(){
  const cols = ['todo','inprogress','review','done'];
  const tasks = filteredTasks();
  const board = document.getElementById('board');
  board.innerHTML = cols.map(s=>{
    const list = tasks.filter(t=>t.status===s);
    return `<div class="column" data-status="${s}">
      <div class="column-head"><span class="column-dot" style="background:${STATUS_META[s].color}"></span><span class="column-title">${STATUS_META[s].label}</span><span class="column-count">${list.length}</span></div>
      <div class="card-list" data-status="${s}">${list.map(taskCardHTML).join('')}</div>
      <button class="add-card-btn" data-status="${s}">+ Add task</button>
    </div>`;
  }).join('');

  board.querySelectorAll('.task-card').forEach(card=>{
    card.addEventListener('dragstart', e=>{ draggedTaskId=card.dataset.id; card.classList.add('dragging'); });
    card.addEventListener('dragend', ()=>{ card.classList.remove('dragging'); });
    card.addEventListener('click', ()=> openTaskModal(card.dataset.id));
  });
  board.querySelectorAll('.column').forEach(col=>{
    col.addEventListener('dragover', e=>{ e.preventDefault(); col.classList.add('drag-over'); });
    col.addEventListener('dragleave', ()=> col.classList.remove('drag-over'));
    col.addEventListener('drop', e=>{
      e.preventDefault(); col.classList.remove('drag-over');
      const t = state.tasks.find(x=>x.id===draggedTaskId);
      if(t){ t.status = col.dataset.status; renderAll(); toast('Task moved to '+STATUS_META[t.status].label, 'check'); }
    });
  });
  board.querySelectorAll('.add-card-btn').forEach(btn=>{
    btn.addEventListener('click', ()=> openTaskModal(null, btn.dataset.status));
  });
}

document.getElementById('filterProject').addEventListener('change', e=>{ state.filters.project=e.target.value; renderBoard(); });
document.getElementById('filterAssignee').addEventListener('change', e=>{ state.filters.assignee=e.target.value; renderBoard(); });
document.getElementById('filterPriority').addEventListener('change', e=>{ state.filters.priority=e.target.value; renderBoard(); });

