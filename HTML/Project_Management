/* ============ CALENDAR ============ */
let calMonth = TODAY.getMonth();
let calYear = TODAY.getFullYear();

function renderCalendar(){
  const title = new Date(calYear, calMonth, 1).toLocaleDateString('en-US',{month:'long', year:'numeric'});
  document.getElementById('calTitle').textContent = title;

  const dows = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  const firstDay = new Date(calYear, calMonth, 1);
  const startOffset = firstDay.getDay();
  const daysInMonth = new Date(calYear, calMonth+1, 0).getDate();
  const daysInPrevMonth = new Date(calYear, calMonth, 0).getDate();

  let cells = [];
  for(let i=startOffset-1;i>=0;i--) cells.push({d:daysInPrevMonth-i, out:true, month:calMonth-1});
  for(let d=1; d<=daysInMonth; d++) cells.push({d, out:false, month:calMonth});
  let nextMonthDay = 1;
  while(cells.length < 42) cells.push({d:nextMonthDay++, out:true, month:calMonth+1});

  let html = dows.map(d=>`<div class="cal-dow">${d}</div>`).join('');
  cells.forEach(cell=>{
    const cellDate = new Date(calYear, cell.month, cell.d);
    const iso = isoDate(cellDate);
    const isToday = iso === isoDate(TODAY);
    const dayTasks = state.tasks.filter(t=>t.due===iso);
    const shown = dayTasks.slice(0,3);
    const more = dayTasks.length - shown.length;
    html += `<div class="cal-cell ${cell.out?'out':''} ${isToday?'today':''}" data-date="${iso}">
      <span class="cal-daynum">${cell.d}</span>
      ${shown.map(t=>`<span class="cal-chip" data-id="${t.id}" style="background:var(${PRIORITY_META[t.priority].tint});color:var(${PRIORITY_META[t.priority].varName})">${t.title}</span>`).join('')}
      ${more>0?`<span class="cal-more">+${more} more</span>`:''}
    </div>`;
  });
  document.getElementById('calGrid').innerHTML = html;

  document.querySelectorAll('.cal-chip').forEach(chip=>{
    chip.addEventListener('click', e=>{ e.stopPropagation(); openTaskModal(chip.dataset.id); });
  });
  document.querySelectorAll('.cal-cell').forEach(cell=>{
    cell.addEventListener('click', ()=> openDayModal(cell.dataset.date));
  });
}
document.getElementById('calPrev').addEventListener('click', ()=>{ calMonth--; if(calMonth<0){calMonth=11;calYear--;} renderCalendar(); });
document.getElementById('calNext').addEventListener('click', ()=>{ calMonth++; if(calMonth>11){calMonth=0;calYear++;} renderCalendar(); });
document.getElementById('calToday').addEventListener('click', ()=>{ calMonth=TODAY.getMonth(); calYear=TODAY.getFullYear(); renderCalendar(); });

const dayModalOverlay = document.getElementById('dayModalOverlay');
let dayModalDate = null;
function openDayModal(iso){
  dayModalDate = iso;
  const d = new Date(iso+'T00:00:00');
  document.getElementById('dayModalTitle').textContent = d.toLocaleDateString('en-US',{weekday:'long', month:'long', day:'numeric'});
  const dayTasks = state.tasks.filter(t=>t.due===iso);
  document.getElementById('dayModalList').innerHTML = dayTasks.length ? dayTasks.map(t=>`
    <div class="mini-task" data-id="${t.id}" style="cursor:pointer;">
      <div class="mini-task-prio" style="background:var(${PRIORITY_META[t.priority].varName})"></div>
      <div class="mini-task-body">
        <div class="mini-task-title">${t.title}</div>
        <div class="mini-task-meta">${projectById(t.projectId)?.name||''} · ${userById(t.assigneeId)?.name||''}</div>
      </div>
      <span class="pill" style="background:${STATUS_META[t.status].color}22;color:${STATUS_META[t.status].color}">${STATUS_META[t.status].label}</span>
    </div>`).join('') : '<p style="color:var(--text-muted);font-size:13px;">No tasks due this day.</p>';
  document.querySelectorAll('#dayModalList .mini-task').forEach(el=>{
    el.addEventListener('click', ()=>{ closeDayModal(); openTaskModal(el.dataset.id); });
