/* ============ ANALYTICS ============ */
let charts = {};
function destroyCharts(){ Object.values(charts).forEach(c=>c && c.destroy()); charts={}; }

function renderAnalytics(){
  destroyCharts();
  const textColor = css('--text-muted');
  const gridColor = css('--border');
  Chart.defaults.font.family = "'Inter', sans-serif";
  Chart.defaults.color = textColor;

  // status doughnut
  const statusCounts = ['todo','inprogress','review','done'].map(s=>state.tasks.filter(t=>t.status===s).length);
  charts.status = new Chart(document.getElementById('chartStatus'), {
    type:'doughnut',
    data:{ labels:Object.values(STATUS_META).map(m=>m.label), datasets:[{ data: statusCounts, backgroundColor:Object.values(STATUS_META).map(m=>m.color), borderWidth:0 }] },
    options:{ plugins:{legend:{position:'bottom', labels:{boxWidth:10,padding:14,font:{size:11}}}}, cutout:'62%' }
  });

  // priority bar
  const prioCounts = ['high','medium','low'].map(p=>state.tasks.filter(t=>t.priority===p).length);
  charts.priority = new Chart(document.getElementById('chartPriority'), {
    type:'bar',
    data:{ labels:['High','Medium','Low'], datasets:[{ data:prioCounts, backgroundColor:[css('--danger'),css('--warning'),css('--accent')], borderRadius:6, maxBarThickness:52 }] },
    options:{ plugins:{legend:{display:false}}, scales:{ y:{beginAtZero:true, ticks:{stepSize:1}, grid:{color:gridColor}}, x:{grid:{display:false}} } }
  });

  // trend line (mock 8-week completion)
  const weeks = Array.from({length:8}, (_,i)=>'W'+(i+1));
  const base = state.tasks.filter(t=>t.status==='done').length;
  const trend = weeks.map((_,i)=> Math.max(0, Math.round(base*0.35 + i*(base/8) + (Math.sin(i)*1.2))));
  charts.trend = new Chart(document.getElementById('chartTrend'), {
    type:'line',
    data:{ labels:weeks, datasets:[{ data:trend, borderColor:css('--primary'), backgroundColor:hexAlpha(css('--primary'),0.15), fill:true, tension:.4, pointRadius:3, pointBackgroundColor:css('--primary') }] },
    options:{ plugins:{legend:{display:false}}, scales:{ y:{beginAtZero:true, grid:{color:gridColor}}, x:{grid:{display:false}} } }
  });

  // workload bar per user
  charts.workload = new Chart(document.getElementById('chartWorkload'), {
    type:'bar',
    data:{
      labels: state.users.map(u=>u.name.split(' ')[0]),
      datasets:[{ label:'Assigned', data: state.users.map(u=>state.tasks.filter(t=>t.assigneeId===u.id).length), backgroundColor: hexAlpha(css('--primary'),0.35), borderRadius:6, maxBarThickness:28 },
                 { label:'Completed', data: state.users.map(u=>state.tasks.filter(t=>t.assigneeId===u.id && t.status==='done').length), backgroundColor: css('--accent'), borderRadius:6, maxBarThickness:28 }]
    },
    options:{ plugins:{legend:{position:'bottom', labels:{boxWidth:10,padding:14,font:{size:11}}}}, scales:{ y:{beginAtZero:true, ticks:{stepSize:1}, grid:{color:gridColor}}, x:{grid:{display:false}} } }
  });
}
function hexAlpha(hex, alpha){
  hex = hex.replace('#','');
  if(hex.length===3) hex = hex.split('').map(c=>c+c).join('');
  const r=parseInt(hex.slice(0,2),16), g=parseInt(hex.slice(2,4),16), b=parseInt(hex.slice(4,6),16);
  return `rgba(${r},${g},${b},${alpha})`;
}

